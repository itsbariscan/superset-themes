---
// Mock code editor surface — exercises sidebar*, card, popover, primary, accent, border, input, ring, mutedForeground, highlight*, chart*.
---
<div class="editor" role="img" aria-label="Code editor mock">
  <aside class="sidebar">
    <div class="sb-head">FILES</div>
    <ul class="sb-tree">
      <li class="sb-item active"><span class="dot"></span>app.ts</li>
      <li class="sb-item">utils.ts</li>
      <li class="sb-item">readme.md</li>
      <li class="sb-group">components</li>
      <li class="sb-item nest">Button.tsx</li>
      <li class="sb-item nest">Input.tsx</li>
    </ul>
    <button class="sb-cta">+ New Agent</button>
  </aside>

  <section class="editor-main">
    <div class="tabbar">
      <div class="tab active">app.ts</div>
      <div class="tab">utils.ts</div>
      <div class="tab">readme.md</div>
    </div>

    <div class="codepane">
      <div class="line"><span class="ln">1</span><span class="kw">import</span> <span class="id">superset</span> <span class="kw">from</span> <span class="str">"@superset.sh/core"</span>;</div>
      <div class="line"><span class="ln">2</span></div>
      <div class="line"><span class="ln">3</span><span class="kw">const</span> <span class="id">agent</span> = <span class="id">superset</span>.<span class="fn">spawn</span>({"({"}</div>
      <div class="line"><span class="ln">4</span>  <span class="prop">model</span>: <span class="str">"claude-opus-4-7"</span>,</div>
      <div class="line"><span class="ln">5</span>  <span class="prop">role</span>: <span class="str">"backend"</span>,</div>
      <div class="line highlight-match"><span class="ln">6</span>  <span class="prop">timeout</span>: <span class="num">30000</span>,</div>
      <div class="line highlight-active"><span class="ln">7</span>{"})"};</div>
      <div class="line"><span class="ln">8</span></div>
      <div class="line"><span class="ln">9</span><span class="kw">await</span> <span class="id">agent</span>.<span class="fn">run</span>(<span class="str">"build the auth flow"</span>);</div>
      <div class="line caret"><span class="ln">10</span><span class="cursor">█</span></div>
    </div>

    <div class="popover" role="dialog" aria-label="Command palette">
      <div class="po-head">Quick command</div>
      <div class="po-input"><input value="rename file" disabled /></div>
      <div class="po-list">
        <div class="po-item">Rename… <span class="po-kbd">⌘R</span></div>
        <div class="po-item active">Move file… <span class="po-kbd">⌘M</span></div>
        <div class="po-item">Delete <span class="po-kbd">⌘⌫</span></div>
      </div>
      <div class="po-actions">
        <button class="btn primary">Run</button>
        <button class="btn secondary">Cancel</button>
        <button class="btn destructive">Stop</button>
      </div>
    </div>

    <div class="charts">
      <div class="chart c1"><span>tokens / s</span></div>
      <div class="chart c2"><span>steps</span></div>
      <div class="chart c3"><span>tools</span></div>
      <div class="chart c4"><span>warnings</span></div>
      <div class="chart c5"><span>errors</span></div>
    </div>
  </section>
</div>

<style>
  .editor {
    display: grid;
    grid-template-columns: 240px 1fr;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    background: var(--background);
    color: var(--foreground);
    height: 540px;
    font-size: 13px;
  }

  /* Sidebar */
  .sidebar {
    background: var(--sidebar);
    color: var(--sidebarForeground);
    border-right: 1px solid var(--sidebarBorder);
    padding: 10px 8px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .sb-head { font-size: 11px; letter-spacing: .1em; opacity: .6; padding: 4px 8px; }
  .sb-tree { list-style: none; padding: 0; margin: 0; flex: 1; }
  .sb-group { padding: 8px 8px 4px; font-size: 11px; letter-spacing: .08em; opacity: .55; text-transform: uppercase; }
  .sb-item {
    padding: 4px 8px;
    border-radius: 6px;
    cursor: default;
    display: flex; align-items: center; gap: 6px;
  }
  .sb-item.nest { padding-left: 22px; }
  .sb-item:hover { background: var(--sidebarAccent); color: var(--sidebarAccentForeground); }
  .sb-item.active {
    background: var(--sidebarPrimary);
    color: var(--sidebarPrimaryForeground);
  }
  .sb-item.active .dot { background: var(--sidebarPrimaryForeground); }
  .dot { display: inline-block; width: 6px; height: 6px; border-radius: 999px; background: var(--mutedForeground); }
  .sb-cta {
    background: transparent;
    color: var(--sidebarForeground);
    border: 1px dashed var(--sidebarBorder);
    border-radius: 8px;
    padding: 8px;
    cursor: pointer;
  }
  .sb-cta:focus-visible { outline: 2px solid var(--sidebarRing); outline-offset: 2px; }

  /* Editor main */
  .editor-main { display: flex; flex-direction: column; min-width: 0; }
  .tabbar {
    display: flex;
    background: var(--secondary);
    color: var(--secondaryForeground);
    border-bottom: 1px solid var(--border);
  }
  .tab {
    padding: 8px 14px;
    font-size: 12px;
    border-right: 1px solid var(--border);
    color: var(--mutedForeground);
  }
  .tab.active {
    background: var(--background);
    color: var(--foreground);
    border-bottom: 2px solid var(--primary);
    margin-bottom: -1px;
  }

  .codepane {
    background: var(--background);
    padding: 12px 0;
    flex: 1;
    overflow: hidden;
    font-family: ui-monospace, "SF Mono", "JetBrains Mono", monospace;
    font-size: 13px;
    line-height: 1.7;
  }
  .line { padding: 0 14px; display: flex; gap: 14px; }
  .line.highlight-match { background: var(--highlightMatch); }
  .line.highlight-active { background: var(--highlightActive); }
  .ln { color: var(--mutedForeground); width: 22px; text-align: right; user-select: none; }
  /* Syntax mapping mirrors superset.sh's source-truth derivation (apps/desktop/src/shared/themes/editor-theme.ts):
       keyword     → terminal.magenta
       string      → terminal.green
       number      → terminal.yellow
       functionCall → terminal.blue
       typeName / constant → terminal.cyan
       comment     → terminal.brightBlack
       variableName → ui.foreground
     The .prop class here represents typeName (for highlighting object literal keys/types). */
  .kw { color: var(--term-magenta); }
  .id { color: var(--foreground); }
  .fn { color: var(--term-blue); }
  .str { color: var(--term-green); }
  .prop { color: var(--term-cyan); }
  .num { color: var(--term-yellow); }
  .cursor { color: var(--ring); animation: blink 1.1s steps(2,end) infinite; }
  @keyframes blink { 50% { opacity: 0 } }

  /* Popover */
  .popover {
    position: relative;
    margin: 12px 14px 0;
    background: var(--popover);
    color: var(--popoverForeground);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px 12px;
    box-shadow: 0 8px 24px rgba(0,0,0,.35);
    width: min(420px, 100%);
  }
  .po-head { font-size: 11px; letter-spacing: .1em; text-transform: uppercase; opacity: .6; margin-bottom: 8px; }
  .po-input input {
    width: 100%;
    background: var(--input);
    color: var(--popoverForeground);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 6px 8px;
    outline: none;
  }
  .po-input input:focus { border-color: var(--ring); box-shadow: 0 0 0 2px var(--ring); }
  .po-list { margin-top: 8px; display: flex; flex-direction: column; }
  .po-item {
    padding: 6px 8px;
    border-radius: 6px;
    display: flex; justify-content: space-between; align-items: center;
    color: var(--popoverForeground);
  }
  .po-item.active {
    background: var(--accent);
    color: var(--accentForeground);
  }
  .po-kbd {
    font-family: ui-monospace, monospace;
    font-size: 11px;
    background: var(--tertiary);
    color: var(--mutedForeground);
    padding: 2px 6px;
    border-radius: 4px;
  }
  .po-actions { display: flex; gap: 6px; margin-top: 10px; }
  .btn {
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 12px;
    cursor: pointer;
  }
  .btn.primary { background: var(--primary); color: var(--primaryForeground); border-color: var(--primary); }
  .btn.secondary { background: var(--secondary); color: var(--secondaryForeground); }
  .btn.destructive { background: var(--destructive); color: var(--destructiveForeground); border-color: var(--destructive); }

  /* Charts */
  .charts {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 6px;
    padding: 10px 14px 14px;
  }
  .chart {
    aspect-ratio: 5 / 1;
    border-radius: 6px;
    display: flex; align-items: end; justify-content: center;
    padding: 4px;
    font-size: 10px;
    color: var(--background);
    font-weight: 600;
  }
  .chart.c1 { background: var(--chart1); }
  .chart.c2 { background: var(--chart2); }
  .chart.c3 { background: var(--chart3); }
  .chart.c4 { background: var(--chart4); }
  .chart.c5 { background: var(--chart5); }
</style>

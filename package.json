{
  "name": "superset-themes",
  "version": "0.0.0",
  "private": true,
  "description": "A curated theme library for superset.sh — 7 ports + 12 originals.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "validate": "bun tools/validate.ts",
    "contrast": "bun tools/contrast.ts",
    "check": "bun run validate && bun run contrast",
    "typecheck": "tsc --noEmit",
    "dev": "bun --cwd apps/site dev",
    "build": "bun --cwd apps/site build",
    "screenshots": "bun tools/screenshot.ts"
  },
  "license": "MIT",
  "author": "Baris Can Sayin <hello@bcsayin.com>",
  "homepage": "https://github.com/itsbariscan/superset-themes",
  "repository": {
    "type": "git",
    "url": "https://github.com/itsbariscan/superset-themes.git"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "playwright": "1.59.1",
    "typescript": "^5.7.2"
  }
}
